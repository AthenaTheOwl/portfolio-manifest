{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio-manifest.dev/schemas/manifest.schema.json",
  "title": "PortfolioManifest",
  "type": "object",
  "required": ["id", "owner", "repos", "contracts", "schedule"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{1,63}$",
      "description": "Manifest identifier. Lowercase, kebab-case."
    },
    "owner": {
      "type": "string",
      "minLength": 1,
      "description": "Human or org responsible for the manifest."
    },
    "schedule": {
      "type": "string",
      "enum": ["weekly", "biweekly", "monthly", "quarterly"],
      "description": "How often the audit runs. v0.1 honours weekly."
    },
    "contracts": {
      "type": "object",
      "required": [
        "decision_schema",
        "spec_schema",
        "dream_schema",
        "voice_lint_banlist",
        "eval_coverage",
        "decision_freshness"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_schema": {
          "type": "object",
          "required": ["latest"],
          "properties": { "latest": { "type": "string" } }
        },
        "spec_schema": {
          "type": "object",
          "required": ["latest"],
          "properties": { "latest": { "type": "string" } }
        },
        "dream_schema": {
          "type": "object",
          "required": ["latest"],
          "properties": { "latest": { "type": "string" } }
        },
        "voice_lint_banlist": {
          "type": "object",
          "required": ["sha256"],
          "properties": { "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
        },
        "eval_coverage": {
          "type": "object",
          "required": ["min_ratio"],
          "properties": {
            "min_ratio": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "decision_freshness": {
          "type": "object",
          "required": ["max_age_days"],
          "properties": {
            "max_age_days": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "clone_url", "branch", "declared_contracts"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,63}$" },
          "clone_url": { "type": "string", "format": "uri" },
          "branch": { "type": "string", "minLength": 1 },
          "declared_contracts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["version"],
              "properties": {
                "version": { "type": "string" },
                "released_at": { "type": "string", "format": "date" }
              }
            }
          },
          "last_audited_at": { "type": "string", "format": "date" },
          "fixture_path": {
            "type": "string",
            "description": "v0.1: where to read check inputs from in lieu of a real clone."
          }
        }
      }
    }
  }
}
