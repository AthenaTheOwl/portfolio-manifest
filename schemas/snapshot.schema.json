{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://portfolio-manifest.dev/schemas/snapshot.schema.json",
  "title": "Snapshot",
  "type": "object",
  "required": ["manifest_id", "iso_week", "repos"],
  "additionalProperties": false,
  "properties": {
    "manifest_id": { "type": "string" },
    "iso_week": {
      "type": "string",
      "pattern": "^[0-9]{4}-W[0-9]{2}$"
    },
    "generated_at": { "type": "string", "format": "date-time" },
    "repos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "check_results", "drift_score"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "drift_score": { "type": "integer", "minimum": 0 },
          "check_results": {
            "type": "array",
            "items": { "$ref": "check-result.schema.json" }
          },
          "drift_events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["contract", "from", "to"],
              "properties": {
                "contract": { "type": "string" },
                "from": { "type": "string", "enum": ["pass", "warn", "fail"] },
                "to": { "type": "string", "enum": ["pass", "warn", "fail"] }
              }
            }
          }
        }
      }
    }
  }
}
